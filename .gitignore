# Environment / secrets — never commit real values
.env
/etc/shortlinks/

# Go build output
/shortlinks
*.exe
*.test
*.out

# Go test cache
/tmp/

# Svelte / Vite build output (embedded into Go binary at compile time)
# The committed dist/index.html placeholder keeps `//go:embed all:dist` and
# therefore `go build ./...` compiling from a clean checkout before any
# `npm run build` has run. The real build overwrites index.html and emits the
# hashed dist/assets/*, which stay ignored.
web/dist/*
!web/dist/index.html
web/node_modules/
web/.svelte-kit/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo
